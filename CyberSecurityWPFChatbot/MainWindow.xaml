<Window x:Class="CyberSecurityWPFChatbot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MOILWA'S CYBER BOT"
        Height="750"
        Width="1000"
        Background="#1E1E2F">

    <Grid Margin="10">

        <!-- ROW DEFINITIONS -->
        <Grid.RowDefinitions>

            <!-- TITLE -->
            <RowDefinition Height="50"/>

            <!-- IMAGE -->
            <RowDefinition Height="180"/>

            <!-- CHAT AREA -->
            <RowDefinition Height="*"/>

            <!-- INPUT AREA -->
            <RowDefinition Height="70"/>

        </Grid.RowDefinitions>

        <!-- TITLE -->
        <Label Content="MOILWA'S CYBER BOT"
               Grid.Row="0"
               FontSize="22"
               FontWeight="Bold"
               Foreground="Cyan"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"/>

        <!-- CYBER IMAGE -->
        <Border Grid.Row="1"
                Margin="20,5,20,5"
                BorderBrush="Cyan"
                BorderThickness="2"
                CornerRadius="10">

            <Image Source="C:\Users\Keaha\Downloads\cyberbot.png"
                   Stretch="UniformToFill"/>
        </Border>

        <!-- CHAT AREA -->
        <RichTextBox Name="rtbChat"
                     Grid.Row="2"
                     Margin="20,10,20,10"
                     FontSize="14"
                     Background="#2A2A40"
                     Foreground="White"
                     BorderBrush="Cyan"
                     BorderThickness="2"
                     IsReadOnly="True"
                     VerticalScrollBarVisibility="Auto"/>

        <!-- INPUT AREA -->
        <Grid Grid.Row="3">

            <!-- USER INPUT -->
            <TextBox Name="txtMessage"
                     Height="40"
                     FontSize="14"
                     Background="#2A2A40"
                     Foreground="White"
                     BorderBrush="Cyan"
                     BorderThickness="2"
                     Margin="20,10,150,10"
                     VerticalContentAlignment="Center"/>

            <!-- SEND BUTTON -->
            <Button Name="btnSend"
                    Content="Send"
                    Width="110"
                    Height="40"
                    FontSize="14"
                    FontWeight="Bold"
                    Background="Cyan"
                    Foreground="Black"
                    HorizontalAlignment="Right"
                    Margin="0,10,20,10"
                    Click="btnSend_Click"/>
        </Grid>

    </Grid>
</Window>