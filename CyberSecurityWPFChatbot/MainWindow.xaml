<Window x:Class="CyberSecurityWPFChatbot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MOILWA'S CYBER BOT"
        Height="620"
        Width="780"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2F">

    <Grid Margin="8">

        <!-- ROW DEFINITIONS -->
        <Grid.RowDefinitions>

            <!-- TITLE -->
            <RowDefinition Height="45"/>

            <!-- IMAGE -->
            <RowDefinition Height="140"/>

            <!-- CHAT AREA -->
            <RowDefinition Height="*"/>

            <!-- INPUT AREA -->
            <RowDefinition Height="60"/>

        </Grid.RowDefinitions>

        <!-- TITLE -->
        <Label Content="MOILWA'S CYBER BOT"
               Grid.Row="0"
               FontSize="18"
               FontWeight="Bold"
               Foreground="Cyan"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"/>

        <!-- IMAGE -->
        <Border Grid.Row="1"
                Margin="15,5,15,5"
                BorderBrush="Cyan"
                BorderThickness="2"
                CornerRadius="8">

            <Image Source="C:\Users\Keaha\Downloads\cyberbot.png"
                   Stretch="UniformToFill"/>
        </Border>

        <!-- CHAT AREA -->
        <RichTextBox Name="rtbChat"
                     Grid.Row="2"
                     Margin="15,8,15,8"
                     FontSize="13"
                     Background="#2A2A40"
                     Foreground="White"
                     BorderBrush="Cyan"
                     BorderThickness="2"
                     IsReadOnly="True"
                     VerticalScrollBarVisibility="Auto"/>

        <!-- INPUT AREA -->
        <Grid Grid.Row="3">

            <!-- USER INPUT -->
            <TextBox Name="txtMessage"
                     Height="35"
                     FontSize="13"
                     Background="#2A2A40"
                     Foreground="White"
                     BorderBrush="Cyan"
                     BorderThickness="2"
                     Margin="15,8,120,8"
                     VerticalContentAlignment="Center"/>

            <!-- SEND BUTTON -->
            <Button Name="btnSend"
                    Content="Send"
                    Width="90"
                    Height="35"
                    FontSize="13"
                    FontWeight="Bold"
                    Background="Cyan"
                    Foreground="Black"
                    HorizontalAlignment="Right"
                    Margin="0,8,15,8"
                    Click="btnSend_Click"/>
            <Button Name="btnHistory"
        Content="History"
        Width="90"
        Height="35"
        HorizontalAlignment="Right"
        Margin="0,8,110,8"
        Click="btnHistory_Click"/>
        </Grid>

    </Grid>
</Window>